--каст к географии
EXPLAIN ANALYZE
SELECT
    id,
    name,
    city,
    address,
    ST_Distance(
        location::geography,
        ST_MakePoint(37.6173, 55.7558)::geography
    ) AS distance_meters
FROM venues
WHERE ST_DWithin(
    location::geography,
    ST_MakePoint(37.6173, 55.7558)::geography,
    10000
)
ORDER BY distance_meters;

